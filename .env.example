# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored; `.env.example` is committed as a template.

# HuggingFace Hub access token. Required for uploading the
# RevivifAI/derestriction dataset via `derestrictor-upload-dataset` and for
# downloading gated models. A read-only token is sufficient for downloads;
# a write-scoped token is required for uploads to the RevivifAI org.
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=
